# Copy to .env and fill in values. .env is gitignored.
# Optional: used when running locally; env vars (e.g. in shell or container) override these.

DATABASE_URL=Host=localhost;Database=bfg;Username=postgres;Password=yourpassword
FRONTEND_URL=
SITE_NAME=BFG

# JWT (use JWT__ prefix for nested config, or set Jwt:SecretKey in appsettings)
JWT__SECRET_KEY=your-secret-key-change-in-production
JWT__ISSUER=bfg-api
JWT__AUDIENCE=bfg-api
JWT__ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT__REFRESH_TOKEN_LIFETIME_DAYS=7
